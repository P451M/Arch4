{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arch4.dev/schemas/arch4-project.schema.json",
  "title": "Arch4ProjectManifest",
  "type": "object",
  "required": ["schemaVersion", "name", "createdAt", "source", "tools"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "createdAt": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["dsl", "entitiesDir", "buildDir"],
      "properties": {
        "dsl": { "type": "string" },
        "entitiesDir": { "type": "string" },
        "buildDir": { "type": "string" }
      }
    },
    "tools": {
      "type": "object",
      "required": ["arch4"],
      "properties": {
        "arch4": { "type": "string" },
        "structurizrCli": { "type": "string" },
        "java": { "type": "string" }
      }
    }
  }
}
