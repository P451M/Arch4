{
  "name": "@arch4/mcp",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "arch4-mcp": "./dist/stdio.js"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/bundle-mcp-package.mjs && vite build && node ../../scripts/inline-mcp-widget.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root . --passWithNoTests --exclude '**/dist/**'"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@arch4/core": "workspace:*",
    "@arch4/viewer": "workspace:*",
    "@arch4/workflows": "workspace:*",
    "@vitejs/plugin-react": "^5.1.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.2.0",
    "vitest": "^4.1.7"
  }
}
